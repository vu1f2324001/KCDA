# Frontend
VITE_API_BASE_URL=https://your-backend.example.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
# Backend
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/kcda_portal?retryWrites=true&w=majority
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
# If you run the frontend on a different localhost port during development,
# set CLIENT_ORIGIN to that origin (example: http://localhost:5102) so cookies
# and credentialed requests work. Leave empty for same-origin production when
# the backend serves the built frontend.
JWT_SECRET=your_jwt_secret_here
CLOUDINARY_URL=

# Notes: Do NOT commit your real secrets to GitHub. Copy this file to .env and fill real values.
