# Backend environment variables example
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/kcda_portal?retryWrites=true&w=majority
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=your_jwt_secret_here
CLOUDINARY_URL=

# Google OAuth
# Obtain this from Google Cloud Console (OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Optional: comma-separated list of allowed admin emails
ADMIN_EMAILS=admin1@example.com,admin2@example.com
# Added sample admin email for convenience

# Copy to backend/.env and fill real values. Do NOT commit .env to Git.
